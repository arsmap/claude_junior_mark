  "permissions": {
    "allow": [
      "Read(~/.claude/plugins/junior_mark/wiki/**)",
      "Bash(python ~/.claude/plugins/junior_mark/scripts/foreman_off.py:*)"
    ]
  },	
  "statusLine": {
    "type": "command",
    "command": "python ~/.claude/plugins/junior_mark/scripts/statusline.py",
    "shell": "bash"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/plugins/junior_mark/scripts/cd_guard.py 2>>\"$HOME/.claude/plugins/junior_mark/debug/hook_stderr.txt\" || true",
            "shell": "bash"
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/plugins/junior_mark/scripts/read_guard.py 2>>\"$HOME/.claude/plugins/junior_mark/debug/hook_stderr.txt\" || true",
            "shell": "bash"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/plugins/junior_mark/scripts/post_tool_use_jm.py 2>>\"$HOME/.claude/plugins/junior_mark/debug/hook_stderr.txt\" || true",
            "shell": "bash"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -u ~/.claude/plugins/junior_mark/scripts/session_start.py",
            "timeout": 30,
            "shell": "bash",
            "statusMessage": "foreman on-air..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/plugins/junior_mark/scripts/signal_checker.py 2>>\"$HOME/.claude/plugins/junior_mark/debug/hook_stderr.txt\" || true",
            "shell": "bash"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -u ~/.claude/plugins/junior_mark/scripts/relay_writer.py 2>>\"$HOME/.claude/plugins/junior_mark/debug/hook_stderr.txt\" || true",
            "shell": "bash"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ~/.claude/plugins/junior_mark/scripts/precompact.py",
            "shell": "bash"
          }
        ]
      }
    ]
  }
